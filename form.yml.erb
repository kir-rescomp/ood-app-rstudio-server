---
cluster: slurm
attributes:
  rstudio_module:
    label: RStudio module
    required: true
    cachable: true
    help: Choose your RStudio module
    widget: select
    options:
      - [ "2025.09.2-418", "RStudio-Server/2025.09.2-418" ]
  rmodule:
    label: R  module
    required: true
    cachable: true
    help: Choose your R module
    widget: select
    options:
      - [ "R/4.5.1-gfbf-2023a-bare-noSciPy", "R/4.5.1-gfbf-2023a-bare-noSciPy" ]
      - [ "R/4.3.2-gfbf-2023a", "R/4.3.2-gfbf-2023a" ]
      - [ "R/4.3.1-foss-2022b", "R/4.3.1-foss-2022b" ]
      - [ "R/4.3.1-foss-2022b-bare", "R/4.3.1-foss-2022b-bare" ]
      - [ "R/4.3.1-foss-2022b-bare-noSciPy", "R/4.3.1-foss-2022b-bare-noSciPy" ]
      - [ "R/4.2.2-foss-2022b", "R/4.2.2-foss-2022b" ]
      - [ "R/4.2.1-foss-2022a", "R/4.2.1-foss-2022a" ]
      - [ "R/4.2.1-foss-2020a-bare" , "R/4.2.1-foss-2020a-bare" ]
      - [ "R/4.2.0-foss-2021b", "R/4.2.0-foss-2021b" ]
      - [ "R/4.1.2-foss-2021b", "R/4.1.2-foss-2021b" ]
      - [ "R/4.0.5-foss-2020b", "R/4.0.5-foss-2020b" ]



  extra_modules_script:
    label: Extra modules script
    help: If you'd like to load additional modules alongside RStudio-Server, put the 'module load ...' commands into a text file (one 'module load...' per line) and specify its path here
    widget: text_field
    required: false
  cores:
    label: Number of CPU cores
    help: How many CPU cores to reserve for your session. NB Ensure this is within the maximum allowed by your chosen partition.
    widget: number_field
    min: 1
    max: 12
    step: 1
    value: 1
    cachable: true
  ram:
    widget: number_field
    label: RAM in GB
    help: How much RAM to reserve for your session. NB Ensure this is within the maximum allowed by your chosen partition
    min: 2
    max:  96
    step: 1
    value: 4
    cachable: true
  bc_num_hours:
    widget: number_field
    help: Maximum runtime in hours for your session. NB Ensure this is within the maximum allowed by your chosen partition
    min: 1
    max: 240
    step: 1
    value: 30
    cachable: true
  bc_email_on_started: false
  auto_modules_RStudio-Server:
    default: false
form:
  - auto_queues
  #- auto_modules_RStudio-Server
  - rstudio_module
  - rmodule
  - extra_modules_script
  - cores
  - ram
  - bc_num_hours
  - bc_email_on_started
